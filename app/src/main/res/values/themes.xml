<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MeowRescue" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_dark</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/text_dark</item>
        <item name="android:colorBackground">@color/background</item>
    </style>

    <style name="Theme.MeowRescue.NoActionBar" parent="Theme.MeowRescue">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>
